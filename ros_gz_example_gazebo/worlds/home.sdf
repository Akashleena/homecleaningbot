    <!-- ================================================================
         PICKUP OBJECTS  — 9 total across both rooms
         Types: toy blocks (box), drink cans (cylinder), balls (sphere)
         All dynamic, primitive collision only, restitution=0.

         Inertia formulae used:
           Solid box  a×b×c at mass m: Ixx = m/12*(b²+c²), etc.
           Solid cylinder r,l at mass m:
             Ixx=Iyy = m/12*(3r²+l²),  Izz = m/2*r²
           Solid sphere radius r at mass m:
             Ixx=Iyy=Izz = 2/5*m*r²

         Object   shape     size            mass   Ixx      Iyy      Izz
         -------  --------  --------------  -----  -------  -------  -------
         toy_r    box       0.06³           0.20   1.2e-4   1.2e-4   1.2e-4
         toy_g    box       0.07×0.05×0.05  0.20   8.3e-5   1.2e-4   1.0e-4
         toy_b    box       0.05³           0.15   6.25e-5  6.25e-5  6.25e-5
         can_y    cylinder  r=0.033,l=0.115 0.18   1.43e-4  1.43e-4  9.8e-5
         can_c    cylinder  r=0.033,l=0.115 0.18   1.43e-4  1.43e-4  9.8e-5
         ball_red sphere    r=0.04          0.12   7.68e-5  7.68e-5  7.68e-5
         ball_blu sphere    r=0.04          0.12   7.68e-5  7.68e-5  7.68e-5
         ball_grn sphere    r=0.035         0.10   4.9e-5   4.9e-5   4.9e-5
         toy_tab  box       0.05³           0.15   6.25e-5  6.25e-5  6.25e-5
                                            (on table — tests 60s stability)

         mu=0.6 for all: slides plausibly when pushed, won't shoot away.
    ================================================================ -->

    <!-- === Room A pickup objects (4) === -->

    <!-- Red toy block -->
    <model name="toy_red">
      <static>false</static><pose>-1.4 -1.6 0.03 0 0 0</pose>
      <link name="link">
        <inertial><mass>0.20</mass>
          <inertia><ixx>0.000120</ixx><iyy>0.000120</iyy><izz>0.000120</izz><ixy>0</ixy><ixz>0</ixz><iyz>0</iyz></inertia></inertial>
        <collision name="col"><geometry><box><size>0.06 0.06 0.06</size></box></geometry>
          <surface><friction><ode><mu>0.6</mu><mu2>0.6</mu2></ode></friction>
            <contact><ode><kp>500000</kp><kd>10</kd><min_depth>0.001</min_depth><max_vel>0.1</max_vel></ode></contact>
            <bounce><restitution_coefficient>0.0</restitution_coefficient><threshold>100000</threshold></bounce>
          </surface></collision>
        <visual name="vis"><geometry><box><size>0.06 0.06 0.06</size></box></geometry>
          <material><ambient>0.90 0.12 0.12 1</ambient><diffuse>0.90 0.12 0.12 1</diffuse></material></visual>
      </link>
    </model>

    <!-- Green toy block (non-cube) -->
