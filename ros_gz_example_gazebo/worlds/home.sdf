<?xml version="1.0" ?>
<sdf version="1.8">
  <world name="home_world">

    <!-- ================================================================
         PHYSICS
         max_step_size = 0.001 s (1 ms)
           Chosen because Gazebo documentation explicitly states that
           smaller step sizes improve contact accuracy at a compute cost.
           1 ms is the recommended high-accuracy default and is sufficient
           for stable small-object pushing and gripper grasping without
           the simulation running slower than real-time on modern hardware.
         real_time_factor = 1.0  (wall-clock sync)
         gravity = -9.81 m/s²    (standard Earth)
    ================================================================ -->
    <gravity>0 0 -9.81</gravity>
    <physics name="home_physics" type="ode">
      <max_step_size>0.001</max_step_size>
      <real_time_factor>1.0</real_time_factor>
      <real_time_update_rate>1000</real_time_update_rate>
    </physics>

    <!-- ===== REQUIRED PLUGINS ===== -->
    <plugin name='gz::sim::systems::Physics'          filename='gz-sim-physics-system'/>
    <plugin name='gz::sim::systems::UserCommands'     filename='gz-sim-user-commands-system'/>
    <plugin name='gz::sim::systems::SceneBroadcaster' filename='gz-sim-scene-broadcaster-system'/>
    <plugin name='gz::sim::systems::Contact'          filename='gz-sim-contact-system'/>
    <plugin name='gz::sim::systems::Sensors'          filename='gz-sim-sensors-system'>
      <render_engine>ogre2</render_engine>
    </plugin>
    <plugin name='gz::sim::systems::Imu' filename='gz-sim-imu-system'/>

    <!-- ================================================================
         LIGHTING
         Directional sun + point fill for Room B so sensors see evenly.
    ================================================================ -->
    <scene>
      <ambient>0.55 0.55 0.55 1</ambient>
      <background>0.88 0.88 0.88 1</background>
      <shadows>true</shadows>
    </scene>

    <light name="sun" type="directional">
      <cast_shadows>true</cast_shadows>
      <pose>0 0 10 0 0 0</pose>
      <diffuse>0.9 0.9 0.9 1</diffuse>
      <specular>0.2 0.2 0.2 1</specular>
      <direction>-0.4 0.2 -1.0</direction>
      <intensity>1.0</intensity>
    </light>

    <light name="fill_b" type="point">
      <pose>3.0 0 1.8 0 0 0</pose>
      <diffuse>0.55 0.55 0.55 1</diffuse>
      <specular>0.05 0.05 0.05 1</specular>
      <attenuation>
        <range>8</range><constant>0.5</constant>
        <linear>0.02</linear><quadratic>0.002</quadratic>
      </attenuation>
    </light>

    <!-- ================================================================
         GROUND PLANE
         Using a large flat box so we can set explicit surface friction.
         The default Gazebo ground plane has mu=0 (frictionless) which
         causes objects to slide unrealistically.

         Friction choice — mu = mu2 = 1.0
           Justification: ODE uses the minimum friction of the two
           contacting bodies. Setting the floor at 1.0 means:
             • Furniture (mu=1.0)  → effective 1.0 — will not slide/tip
             • Pickup objects (mu=0.6) → effective 0.6 — slides when
               pushed but settles without drifting
             • Robot wheels (mu=1.0) → effective 1.0 — good traction
           A value of 1.0 represents a typical indoor hard floor
           (wood/tile). It avoids the physics-failure modes of either
           frictionless surfaces (objects skate) or very high friction
           (objects lock unrealistically to the floor).
    ================================================================ -->
    <model name="ground_plane">
      <static>true</static>
      <link name="link">
        <collision name="collision">
          <pose>0 0 -0.05 0 0 0</pose>
          <geometry><box><size>12 10 0.1</size></box></geometry>
          <surface>
            <friction>
              <ode><mu>1.0</mu><mu2>1.0</mu2></ode>
            </friction>
            <contact><ode><kp>1000000</kp><kd>100</kd></ode></contact>
          </surface>
        </collision>
        <visual name="visual">
          <pose>0 0 -0.05 0 0 0</pose>
          <geometry><box><size>12 10 0.1</size></box></geometry>
          <material>
            <ambient>0.76 0.70 0.62 1</ambient>
            <diffuse>0.76 0.70 0.62 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <!-- ================================================================
         ROOM LAYOUT
         Robot chassis 0.4×0.3 m, wheel radius 0.1 m, spawns at (0,0,0).
         Divider at x=+1.0 → robot starts ~1 m inside Room A.

           Room A (robot start+collection): x=-4 … +1,  y=-2.5 … +2.5
           Room B (extra furniture):        x=+1 … +4,  y=-2.5 … +2.5
           Doorway: y=-0.5 … +0.5  (1.0 m clear — 2.2× robot width)
           Wall thickness 0.12 m,  wall height 2.0 m
    ================================================================ -->

    <!-- Outer walls -->
    <model name="wall_left">
      <static>true</static><pose>-4.06 0 1.0 0 0 0</pose>
      <link name="link">
        <collision name="col"><geometry><box><size>0.12 5.24 2.0</size></box></geometry>
          <surface><friction><ode><mu>1.0</mu><mu2>1.0</mu2></ode></friction></surface></collision>
        <visual name="vis"><geometry><box><size>0.12 5.24 2.0</size></box></geometry>
          <material><ambient>0.92 0.88 0.82 1</ambient><diffuse>0.92 0.88 0.82 1</diffuse></material></visual>
      </link>
    </model>

    <model name="wall_right">
      <static>true</static><pose>4.06 0 1.0 0 0 0</pose>
      <link name="link">
        <collision name="col"><geometry><box><size>0.12 5.24 2.0</size></box></geometry>
          <surface><friction><ode><mu>1.0</mu><mu2>1.0</mu2></ode></friction></surface></collision>
        <visual name="vis"><geometry><box><size>0.12 5.24 2.0</size></box></geometry>
          <material><ambient>0.92 0.88 0.82 1</ambient><diffuse>0.92 0.88 0.82 1</diffuse></material></visual>
      </link>
    </model>

    <model name="wall_front">
      <static>true</static><pose>0 -2.56 1.0 0 0 0</pose>
      <link name="link">
        <collision name="col"><geometry><box><size>8.24 0.12 2.0</size></box></geometry>
          <surface><friction><ode><mu>1.0</mu><mu2>1.0</mu2></ode></friction></surface></collision>
        <visual name="vis"><geometry><box><size>8.24 0.12 2.0</size></box></geometry>
          <material><ambient>0.92 0.88 0.82 1</ambient><diffuse>0.92 0.88 0.82 1</diffuse></material></visual>
      </link>
    </model>

    <model name="wall_back">
      <static>true</static><pose>0 2.56 1.0 0 0 0</pose>
      <link name="link">
        <collision name="col"><geometry><box><size>8.24 0.12 2.0</size></box></geometry>
          <surface><friction><ode><mu>1.0</mu><mu2>1.0</mu2></ode></friction></surface></collision>
        <visual name="vis"><geometry><box><size>8.24 0.12 2.0</size></box></geometry>
          <material><ambient>0.92 0.88 0.82 1</ambient><diffuse>0.92 0.88 0.82 1</diffuse></material></visual>
      </link>
    </model>

    <!-- Dividing wall — lower segment (y = -2.5 to -0.5) -->
    <model name="divider_lower">
      <static>true</static><pose>1.0 -1.5 1.0 0 0 0</pose>
      <link name="link">
        <collision name="col"><geometry><box><size>0.12 2.0 2.0</size></box></geometry>
          <surface><friction><ode><mu>1.0</mu><mu2>1.0</mu2></ode></friction></surface></collision>
        <visual name="vis"><geometry><box><size>0.12 2.0 2.0</size></box></geometry>
          <material><ambient>0.85 0.82 0.78 1</ambient><diffuse>0.85 0.82 0.78 1</diffuse></material></visual>
      </link>
    </model>

    <!-- Dividing wall — upper segment (y = +0.5 to +2.5) -->
    <model name="divider_upper">
      <static>true</static><pose>1.0 1.5 1.0 0 0 0</pose>
      <link name="link">
        <collision name="col"><geometry><box><size>0.12 2.0 2.0</size></box></geometry>
          <surface><friction><ode><mu>1.0</mu><mu2>1.0</mu2></ode></friction></surface></collision>
        <visual name="vis"><geometry><box><size>0.12 2.0 2.0</size></box></geometry>
          <material><ambient>0.85 0.82 0.78 1</ambient><diffuse>0.85 0.82 0.78 1</diffuse></material></visual>
      </link>
    </model>

    <!-- Lintel above doorway gap -->
    <model name="doorway_lintel">
      <static>true</static><pose>1.0 0 1.85 0 0 0</pose>
      <link name="link">
        <collision name="col"><geometry><box><size>0.12 1.0 0.3</size></box></geometry></collision>
        <visual name="vis"><geometry><box><size>0.12 1.0 0.3</size></box></geometry>
          <material><ambient>0.85 0.82 0.78 1</ambient><diffuse>0.85 0.82 0.78 1</diffuse></material></visual>
      </link>
    </model>

    <!-- ================================================================
         COLLECTION BOX  — large open-topped bin near robot start
         Placed at (-3.0, 0.0): ~3 m ahead of robot, against left side.
         Size 0.80 × 0.60 m footprint, 0.40 m tall walls — large enough
         that a grabbed object dropped from gripper height lands inside.
         Interior mu=1.2 so dropped objects settle and do not bounce out.
         (ODE effective mu = min(1.2, object_mu=0.6) = 0.6 — they rest.)
         Colour: bright orange so it is easy to identify in camera feed.
    ================================================================ -->
    <model name="collection_box">
      <static>true</static>
      <pose>-3.0 0.0 0 0 0 0</pose>
      <link name="link">
        <!-- Floor of box -->
        <collision name="floor_col">
          <pose>0 0 0.03 0 0 0</pose>
          <geometry><box><size>0.80 0.60 0.06</size></box></geometry>
          <surface><friction><ode><mu>1.2</mu><mu2>1.2</mu2></ode></friction></surface>
        </collision>
        <visual name="floor_vis">
          <pose>0 0 0.03 0 0 0</pose>
          <geometry><box><size>0.80 0.60 0.06</size></box></geometry>
          <material><ambient>0.90 0.50 0.05 1</ambient><diffuse>0.90 0.50 0.05 1</diffuse></material>
        </visual>
        <!-- Front wall -->
        <collision name="fw_col"><pose>0 -0.30 0.27 0 0 0</pose>
          <geometry><box><size>0.80 0.04 0.48</size></box></geometry>
          <surface><friction><ode><mu>1.2</mu><mu2>1.2</mu2></ode></friction></surface></collision>
        <visual name="fw_vis"><pose>0 -0.30 0.27 0 0 0</pose>
          <geometry><box><size>0.80 0.04 0.48</size></box></geometry>
          <material><ambient>0.90 0.50 0.05 1</ambient><diffuse>0.90 0.50 0.05 1</diffuse></material></visual>
        <!-- Back wall -->
        <collision name="bw_col"><pose>0  0.30 0.27 0 0 0</pose>
          <geometry><box><size>0.80 0.04 0.48</size></box></geometry>
          <surface><friction><ode><mu>1.2</mu><mu2>1.2</mu2></ode></friction></surface></collision>
        <visual name="bw_vis"><pose>0  0.30 0.27 0 0 0</pose>
          <geometry><box><size>0.80 0.04 0.48</size></box></geometry>
          <material><ambient>0.90 0.50 0.05 1</ambient><diffuse>0.90 0.50 0.05 1</diffuse></material></visual>
        <!-- Left wall -->
        <collision name="lw_col"><pose> 0.40 0 0.27 0 0 0</pose>
          <geometry><box><size>0.04 0.60 0.48</size></box></geometry>
          <surface><friction><ode><mu>1.2</mu><mu2>1.2</mu2></ode></friction></surface></collision>
        <visual name="lw_vis"><pose> 0.40 0 0.27 0 0 0</pose>
          <geometry><box><size>0.04 0.60 0.48</size></box></geometry>
          <material><ambient>0.90 0.50 0.05 1</ambient><diffuse>0.90 0.50 0.05 1</diffuse></material></visual>
        <!-- Right wall -->
        <collision name="rw_col"><pose>-0.40 0 0.27 0 0 0</pose>
          <geometry><box><size>0.04 0.60 0.48</size></box></geometry>
          <surface><friction><ode><mu>1.2</mu><mu2>1.2</mu2></ode></friction></surface></collision>
        <visual name="rw_vis"><pose>-0.40 0 0.27 0 0 0</pose>
          <geometry><box><size>0.04 0.60 0.48</size></box></geometry>
          <material><ambient>0.90 0.50 0.05 1</ambient><diffuse>0.90 0.50 0.05 1</diffuse></material></visual>
      </link>
    </model>

    <!-- ================================================================
         FURNITURE — Room A  (x < 1.0)
         All static — cannot tip or slide on robot contact (rubric req).
    ================================================================ -->

    <model name="table_a">
      <static>true</static><pose>-2.0 1.5 0 0 0 0</pose>
      <link name="link">
        <collision name="top_col"><pose>0 0 0.77 0 0 0</pose>
          <geometry><box><size>1.0 0.6 0.05</size></box></geometry>
          <surface><friction><ode><mu>1.0</mu><mu2>1.0</mu2></ode></friction></surface></collision>
        <visual name="top_vis"><pose>0 0 0.77 0 0 0</pose>
          <geometry><box><size>1.0 0.6 0.05</size></box></geometry>
          <material><ambient>0.55 0.35 0.18 1</ambient><diffuse>0.55 0.35 0.18 1</diffuse></material></visual>
        <collision name="l1"><pose> 0.43  0.23 0.375 0 0 0</pose><geometry><box><size>0.05 0.05 0.75</size></box></geometry></collision>
        <visual    name="v1"><pose> 0.43  0.23 0.375 0 0 0</pose><geometry><box><size>0.05 0.05 0.75</size></box></geometry><material><ambient>0.4 0.25 0.1 1</ambient><diffuse>0.4 0.25 0.1 1</diffuse></material></visual>
        <collision name="l2"><pose> 0.43 -0.23 0.375 0 0 0</pose><geometry><box><size>0.05 0.05 0.75</size></box></geometry></collision>
        <visual    name="v2"><pose> 0.43 -0.23 0.375 0 0 0</pose><geometry><box><size>0.05 0.05 0.75</size></box></geometry><material><ambient>0.4 0.25 0.1 1</ambient><diffuse>0.4 0.25 0.1 1</diffuse></material></visual>
        <collision name="l3"><pose>-0.43  0.23 0.375 0 0 0</pose><geometry><box><size>0.05 0.05 0.75</size></box></geometry></collision>
        <visual    name="v3"><pose>-0.43  0.23 0.375 0 0 0</pose><geometry><box><size>0.05 0.05 0.75</size></box></geometry><material><ambient>0.4 0.25 0.1 1</ambient><diffuse>0.4 0.25 0.1 1</diffuse></material></visual>
        <collision name="l4"><pose>-0.43 -0.23 0.375 0 0 0</pose><geometry><box><size>0.05 0.05 0.75</size></box></geometry></collision>
        <visual    name="v4"><pose>-0.43 -0.23 0.375 0 0 0</pose><geometry><box><size>0.05 0.05 0.75</size></box></geometry><material><ambient>0.4 0.25 0.1 1</ambient><diffuse>0.4 0.25 0.1 1</diffuse></material></visual>
      </link>
    </model>

    <model name="chair_a1">
      <static>true</static><pose>-2.0 0.75 0 0 0 3.14159</pose>
      <link name="link">
        <collision name="s"><pose>0 0 0.45 0 0 0</pose><geometry><box><size>0.40 0.40 0.05</size></box></geometry></collision>
        <visual    name="sv"><pose>0 0 0.45 0 0 0</pose><geometry><box><size>0.40 0.40 0.05</size></box></geometry><material><ambient>0.25 0.35 0.65 1</ambient><diffuse>0.25 0.35 0.65 1</diffuse></material></visual>
        <collision name="b"><pose>0 0.18 0.70 0 0 0</pose><geometry><box><size>0.40 0.05 0.46</size></box></geometry></collision>
        <visual    name="bv"><pose>0 0.18 0.70 0 0 0</pose><geometry><box><size>0.40 0.05 0.46</size></box></geometry><material><ambient>0.25 0.35 0.65 1</ambient><diffuse>0.25 0.35 0.65 1</diffuse></material></visual>
        <collision name="l1"><pose> 0.17  0.17 0.22 0 0 0</pose><geometry><box><size>0.04 0.04 0.44</size></box></geometry></collision><visual name="lv1"><pose> 0.17  0.17 0.22 0 0 0</pose><geometry><box><size>0.04 0.04 0.44</size></box></geometry></visual>
        <collision name="l2"><pose>-0.17  0.17 0.22 0 0 0</pose><geometry><box><size>0.04 0.04 0.44</size></box></geometry></collision><visual name="lv2"><pose>-0.17  0.17 0.22 0 0 0</pose><geometry><box><size>0.04 0.04 0.44</size></box></geometry></visual>
        <collision name="l3"><pose> 0.17 -0.17 0.22 0 0 0</pose><geometry><box><size>0.04 0.04 0.44</size></box></geometry></collision><visual name="lv3"><pose> 0.17 -0.17 0.22 0 0 0</pose><geometry><box><size>0.04 0.04 0.44</size></box></geometry></visual>
        <collision name="l4"><pose>-0.17 -0.17 0.22 0 0 0</pose><geometry><box><size>0.04 0.04 0.44</size></box></geometry></collision><visual name="lv4"><pose>-0.17 -0.17 0.22 0 0 0</pose><geometry><box><size>0.04 0.04 0.44</size></box></geometry></visual>
      </link>
    </model>

    <model name="chair_a2">
      <static>true</static><pose>-2.0 2.2 0 0 0 0</pose>
      <link name="link">
        <collision name="s"><pose>0 0 0.45 0 0 0</pose><geometry><box><size>0.40 0.40 0.05</size></box></geometry></collision>
        <visual    name="sv"><pose>0 0 0.45 0 0 0</pose><geometry><box><size>0.40 0.40 0.05</size></box></geometry><material><ambient>0.25 0.35 0.65 1</ambient><diffuse>0.25 0.35 0.65 1</diffuse></material></visual>
        <collision name="b"><pose>0 0.18 0.70 0 0 0</pose><geometry><box><size>0.40 0.05 0.46</size></box></geometry></collision>
        <visual    name="bv"><pose>0 0.18 0.70 0 0 0</pose><geometry><box><size>0.40 0.05 0.46</size></box></geometry><material><ambient>0.25 0.35 0.65 1</ambient><diffuse>0.25 0.35 0.65 1</diffuse></material></visual>
        <collision name="l1"><pose> 0.17  0.17 0.22 0 0 0</pose><geometry><box><size>0.04 0.04 0.44</size></box></geometry></collision><visual name="lv1"><pose> 0.17  0.17 0.22 0 0 0</pose><geometry><box><size>0.04 0.04 0.44</size></box></geometry></visual>
        <collision name="l2"><pose>-0.17  0.17 0.22 0 0 0</pose><geometry><box><size>0.04 0.04 0.44</size></box></geometry></collision><visual name="lv2"><pose>-0.17  0.17 0.22 0 0 0</pose><geometry><box><size>0.04 0.04 0.44</size></box></geometry></visual>
        <collision name="l3"><pose> 0.17 -0.17 0.22 0 0 0</pose><geometry><box><size>0.04 0.04 0.44</size></box></geometry></collision><visual name="lv3"><pose> 0.17 -0.17 0.22 0 0 0</pose><geometry><box><size>0.04 0.04 0.44</size></box></geometry></visual>
        <collision name="l4"><pose>-0.17 -0.17 0.22 0 0 0</pose><geometry><box><size>0.04 0.04 0.44</size></box></geometry></collision><visual name="lv4"><pose>-0.17 -0.17 0.22 0 0 0</pose><geometry><box><size>0.04 0.04 0.44</size></box></geometry></visual>
      </link>
    </model>

    <model name="shelf_a">
      <static>true</static><pose>-3.6 -1.5 0 0 0 0</pose>
      <link name="link">
        <collision name="back"><pose>0 0.08 0.6 0 0 0</pose><geometry><box><size>0.75 0.05 1.2</size></box></geometry>
          <surface><friction><ode><mu>1.0</mu><mu2>1.0</mu2></ode></friction></surface></collision>
        <visual name="backv"><pose>0 0.08 0.6 0 0 0</pose><geometry><box><size>0.75 0.05 1.2</size></box></geometry>
          <material><ambient>0.6 0.45 0.25 1</ambient><diffuse>0.6 0.45 0.25 1</diffuse></material></visual>
        <collision name="s1"><pose>0 -0.08 0.25 0 0 0</pose><geometry><box><size>0.75 0.28 0.03</size></box></geometry></collision>
        <visual    name="s1v"><pose>0 -0.08 0.25 0 0 0</pose><geometry><box><size>0.75 0.28 0.03</size></box></geometry><material><ambient>0.6 0.45 0.25 1</ambient><diffuse>0.6 0.45 0.25 1</diffuse></material></visual>
        <collision name="s2"><pose>0 -0.08 0.60 0 0 0</pose><geometry><box><size>0.75 0.28 0.03</size></box></geometry></collision>
        <visual    name="s2v"><pose>0 -0.08 0.60 0 0 0</pose><geometry><box><size>0.75 0.28 0.03</size></box></geometry><material><ambient>0.6 0.45 0.25 1</ambient><diffuse>0.6 0.45 0.25 1</diffuse></material></visual>
        <collision name="s3"><pose>0 -0.08 0.95 0 0 0</pose><geometry><box><size>0.75 0.28 0.03</size></box></geometry></collision>
        <visual    name="s3v"><pose>0 -0.08 0.95 0 0 0</pose><geometry><box><size>0.75 0.28 0.03</size></box></geometry><material><ambient>0.6 0.45 0.25 1</ambient><diffuse>0.6 0.45 0.25 1</diffuse></material></visual>
      </link>
    </model>

    <!-- ================================================================
         FURNITURE — Room B  (x > 1.0)
    ================================================================ -->

    <model name="table_b">
      <static>true</static><pose>2.5 -1.0 0 0 0 0</pose>
      <link name="link">
        <collision name="top_col"><pose>0 0 0.77 0 0 0</pose>
          <geometry><box><size>1.0 0.6 0.05</size></box></geometry>
          <surface><friction><ode><mu>1.0</mu><mu2>1.0</mu2></ode></friction></surface></collision>
        <visual name="top_vis"><pose>0 0 0.77 0 0 0</pose>
          <geometry><box><size>1.0 0.6 0.05</size></box></geometry>
          <material><ambient>0.55 0.35 0.18 1</ambient><diffuse>0.55 0.35 0.18 1</diffuse></material></visual>
        <collision name="l1"><pose> 0.43  0.23 0.375 0 0 0</pose><geometry><box><size>0.05 0.05 0.75</size></box></geometry></collision>
        <visual    name="v1"><pose> 0.43  0.23 0.375 0 0 0</pose><geometry><box><size>0.05 0.05 0.75</size></box></geometry><material><ambient>0.4 0.25 0.1 1</ambient><diffuse>0.4 0.25 0.1 1</diffuse></material></visual>
        <collision name="l2"><pose> 0.43 -0.23 0.375 0 0 0</pose><geometry><box><size>0.05 0.05 0.75</size></box></geometry></collision>
        <visual    name="v2"><pose> 0.43 -0.23 0.375 0 0 0</pose><geometry><box><size>0.05 0.05 0.75</size></box></geometry><material><ambient>0.4 0.25 0.1 1</ambient><diffuse>0.4 0.25 0.1 1</diffuse></material></visual>
        <collision name="l3"><pose>-0.43  0.23 0.375 0 0 0</pose><geometry><box><size>0.05 0.05 0.75</size></box></geometry></collision>
        <visual    name="v3"><pose>-0.43  0.23 0.375 0 0 0</pose><geometry><box><size>0.05 0.05 0.75</size></box></geometry><material><ambient>0.4 0.25 0.1 1</ambient><diffuse>0.4 0.25 0.1 1</diffuse></material></visual>
        <collision name="l4"><pose>-0.43 -0.23 0.375 0 0 0</pose><geometry><box><size>0.05 0.05 0.75</size></box></geometry></collision>
        <visual    name="v4"><pose>-0.43 -0.23 0.375 0 0 0</pose><geometry><box><size>0.05 0.05 0.75</size></box></geometry><material><ambient>0.4 0.25 0.1 1</ambient><diffuse>0.4 0.25 0.1 1</diffuse></material></visual>
      </link>
    </model>

    <model name="chair_b1">
      <static>true</static><pose>2.5 -1.75 0 0 0 0</pose>
      <link name="link">
        <collision name="s"><pose>0 0 0.45 0 0 0</pose><geometry><box><size>0.40 0.40 0.05</size></box></geometry></collision>
