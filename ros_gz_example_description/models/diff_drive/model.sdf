<sdf version="1.8">
  <model name="diff_drive">
  <self_collide>false</self_collide>

    <!-- ═══════════════════════════════════════════════
         CHASSIS
         Size: 0.4 × 0.3 × 0.15 m   mass: 5.0 kg
         z pose = wheel_radius + chassis_half_height
                = 0.1 + 0.075 = 0.175 m
         Inertia (box): your values from the tool are correct
           Ixx = 5/12*(0.3²+0.15²) = 0.046875
           Iyy = 5/12*(0.4²+0.15²) = 0.076041
           Izz = 5/12*(0.4²+0.3²)  = 0.104166
         ═══════════════════════════════════════════════ -->
    <link name="chassis">
      <pose>0 0 0.175 0 0 0</pose> 
      <inertial>
        <mass>5.0</mass>
        <inertia>
          <ixx>0.046875</ixx><ixy>0</ixy><ixz>0</ixz>
          <iyy>0.076041</iyy><iyz>0</iyz>
          <izz>0.104166</izz>
        </inertia>
      </inertial>
      <visual name="visual_chassis">
        <geometry><box><size>0.4 0.3 0.15</size></box></geometry>
        <material>
          <ambient>0.2 0.2 0.8 1</ambient>
          <diffuse>0.2 0.2 0.8 1</diffuse>
          <specular>0.3 0.3 0.3 1</specular>
        </material>
      </visual>
      <collision name="collision_chassis">
        <geometry><box><size>0.4 0.3 0.15</size></box></geometry>
        <surface>
          <friction><ode><mu>0.6</mu><mu2>0.6</mu2></ode></friction>
          <contact><ode><min_depth>0.001</min_depth></ode></contact>
        </surface>
      </collision>
    </link>

    <!-- ═══════════════════════════════════════════════
         WHEELS  (4 ×)
         r=0.1m  l=0.05m  mass=0.5kg
         Inertia (cylinder, FIXED from 0.00135):
           Ixx=Iyy = 0.5/12*(3×0.01+0.0025) = 0.00219
           Izz     = 0.5/2 × 0.01           = 0.00250

         Pose relative to chassis:
           x = ±0.15  (half wheelbase)
           y = ±(chassis_half_W + wheel_half_L)
             = ±(0.15 + 0.025) = ±0.175
           z = -(chassis_half_H) = -0.075
           rotation = -1.5708 around x (lay cylinder on side)
         ═══════════════════════════════════════════════ -->

    <!-- FRONT LEFT -->
    <link name="front_left_wheel">
      <pose relative_to="chassis">0.15 0.175 -0.075 -1.5708 0 0</pose>
      <inertial>
        <mass>0.5</mass>
        <inertia>
          <ixx>0.00219</ixx><ixy>0</ixy><ixz>0</ixz>
          <iyy>0.00219</iyy><iyz>0</iyz>
          <izz>0.00250</izz>
        </inertia>
      </inertial>
      <visual name="visual">
        <geometry><cylinder><radius>0.1</radius><length>0.05</length></cylinder></geometry>
        <material>
          <ambient>0.1 0.1 0.1 1</ambient>
          <diffuse>0.1 0.1 0.1 1</diffuse>
        </material>
      </visual>
      <collision name="collision">
        <geometry><cylinder><radius>0.1</radius><length>0.05</length></cylinder></geometry>
        <surface>
          <friction><ode><mu>1.0</mu><mu2>0.7</mu2></ode></friction>
          <contact><ode><min_depth>0.001</min_depth><kp>1e6</kp><kd>100</kd></ode></contact>
        </surface>
      </collision>
    </link>

    <joint name="front_left_wheel_joint" type="revolute">
      <pose relative_to="front_left_wheel"/>
      <parent>chassis</parent>
      <child>front_left_wheel</child>
      <axis>
        <xyz expressed_in="__model__">0 1 0</xyz>  <!-- FIXED: was 0 0 1 -->
        <limit>
          <lower>-1.79769e+308</lower>
          <upper>1.79769e+308</upper>
          <effort>15.0</effort>
          <velocity>10.0</velocity>
        </limit>
        <dynamics>
          <damping>0.1</damping>   <!-- FIXED: was 0.5 — too high -->
          <friction>0.02</friction> <!-- FIXED: was 0.7 — too high -->
        </dynamics>
      </axis>
    </joint>

    <!-- FRONT RIGHT -->
    <link name="front_right_wheel">
      <pose relative_to="chassis">0.15 -0.175 -0.075 -1.5708 0 0</pose>
      <inertial>
        <mass>0.5</mass>
        <inertia>
          <ixx>0.00219</ixx><ixy>0</ixy><ixz>0</ixz>
          <iyy>0.00219</iyy><iyz>0</iyz>
          <izz>0.00250</izz>
        </inertia>
      </inertial>
      <visual name="visual">
        <geometry><cylinder><radius>0.1</radius><length>0.05</length></cylinder></geometry>
        <material>
          <ambient>0.1 0.1 0.1 1</ambient>
          <diffuse>0.1 0.1 0.1 1</diffuse>
        </material>
      </visual>
      <collision name="collision">
        <geometry><cylinder><radius>0.1</radius><length>0.05</length></cylinder></geometry>
        <surface>
          <friction><ode><mu>1.0</mu><mu2>0.7</mu2></ode></friction>
          <contact><ode><min_depth>0.001</min_depth><kp>1e6</kp><kd>100</kd></ode></contact>
        </surface>
      </collision>
    </link>

    <joint name="front_right_wheel_joint" type="revolute">
      <pose relative_to="front_right_wheel"/>
      <parent>chassis</parent>
      <child>front_right_wheel</child>
      <axis>
        <xyz expressed_in="__model__">0 1 0</xyz>
        <limit>
          <lower>-1.79769e+308</lower>
          <upper>1.79769e+308</upper>
          <effort>15.0</effort>
          <velocity>10.0</velocity>
        </limit>
        <dynamics>
          <damping>0.1</damping>
          <friction>0.02</friction>
        </dynamics>
      </axis>
    </joint>

    <!-- REAR LEFT -->
    <link name="rear_left_wheel">
      <pose relative_to="chassis">-0.15 0.175 -0.075 -1.5708 0 0</pose>
      <inertial>
        <mass>0.5</mass>
        <inertia>
          <ixx>0.00219</ixx><ixy>0</ixy><ixz>0</ixz>
          <iyy>0.00219</iyy><iyz>0</iyz>
          <izz>0.00250</izz>
        </inertia>
      </inertial>
      <visual name="visual">
        <geometry><cylinder><radius>0.1</radius><length>0.05</length></cylinder></geometry>
        <material>
          <ambient>0.1 0.1 0.1 1</ambient>
          <diffuse>0.1 0.1 0.1 1</diffuse>
        </material>
      </visual>
      <collision name="collision">
        <geometry><cylinder><radius>0.1</radius><length>0.05</length></cylinder></geometry>
        <surface>
          <friction><ode><mu>1.0</mu><mu2>0.7</mu2></ode></friction>
          <contact><ode><min_depth>0.001</min_depth><kp>1e6</kp><kd>100</kd></ode></contact>
        </surface>
      </collision>
    </link>

    <joint name="rear_left_wheel_joint" type="revolute">
      <pose relative_to="rear_left_wheel"/>
      <parent>chassis</parent>
      <child>rear_left_wheel</child>
      <axis>
        <xyz expressed_in="__model__">0 1 0</xyz>
        <limit>
          <lower>-1.79769e+308</lower>
          <upper>1.79769e+308</upper>
          <effort>15.0</effort>
          <velocity>10.0</velocity>
        </limit>
        <dynamics>
          <damping>0.1</damping>
          <friction>0.02</friction>
        </dynamics>
      </axis>
    </joint>

    <!-- REAR RIGHT -->
    <link name="rear_right_wheel">
      <pose relative_to="chassis">-0.15 -0.175 -0.075 -1.5708 0 0</pose>
      <inertial>
        <mass>0.5</mass>
        <inertia>
          <ixx>0.00219</ixx><ixy>0</ixy><ixz>0</ixz>
          <iyy>0.00219</iyy><iyz>0</iyz>
          <izz>0.00250</izz>
        </inertia>
      </inertial>
      <visual name="visual">
        <geometry><cylinder><radius>0.1</radius><length>0.05</length></cylinder></geometry>
        <material>
          <ambient>0.1 0.1 0.1 1</ambient>
          <diffuse>0.1 0.1 0.1 1</diffuse>
        </material>
      </visual>
      <collision name="collision">
        <geometry><cylinder><radius>0.1</radius><length>0.05</length></cylinder></geometry>
        <surface>
          <friction><ode><mu>1.0</mu><mu2>0.7</mu2></ode></friction>
          <contact><ode><min_depth>0.001</min_depth><kp>1e6</kp><kd>100</kd></ode></contact>
        </surface>
      </collision>
    </link>

    <joint name="rear_right_wheel_joint" type="revolute">
      <pose relative_to="rear_right_wheel"/>
      <parent>chassis</parent>
      <child>rear_right_wheel</child>
      <axis>
        <xyz expressed_in="__model__">0 1 0</xyz>
        <limit>
          <lower>-1.79769e+308</lower>
          <upper>1.79769e+308</upper>
          <effort>15.0</effort>
          <velocity>10.0</velocity>
        </limit>
        <dynamics>
          <damping>0.1</damping>
          <friction>0.02</friction>
        </dynamics>
      </axis>
    </joint>
    <!-- ═══════════════════════════════════════════════════
     TORSO
     Box: 0.20 × 0.15 × 0.40 m   mass: 3.0 kg
     Pose relative to chassis:
       z = chassis_half_H + torso_half_H = 0.075 + 0.200 = 0.275m
     Ixx = 3/12*(0.15²+0.40²) = 0.045625
     Iyy = 3/12*(0.20²+0.40²) = 0.050000
     Izz = 3/12*(0.20²+0.15²) = 0.015625
     ═══════════════════════════════════════════════════ -->
<link name="torso">
  <pose relative_to="chassis">0.0 0.0 0.275 0 0 0</pose>
  <inertial>
    <mass>3.0</mass>
    <inertia>
      <ixx>0.045625</ixx><ixy>0</ixy><ixz>0</ixz>
      <iyy>0.050000</iyy><iyz>0</iyz>
      <izz>0.015625</izz>
    </inertia>
  </inertial>
  <visual name="torso_visual">
    <geometry><box><size>0.20 0.15 0.40</size></box></geometry>
    <material>
      <ambient>0.7 0.7 0.9 1</ambient>
      <diffuse>0.7 0.7 0.9 1</diffuse>
      <specular>0.3 0.3 0.3 1</specular>
    </material>
  </visual>
  <collision name="torso_collision">
    <geometry><box><size>0.20 0.15 0.40</size></box></geometry>
    <surface>
      <friction><ode><mu>0.6</mu><mu2>0.6</mu2></ode></friction>
    </surface>
  </collision>

  <!-- ── RGB-D CAMERA ──────────────────────────────────
       Mounted on torso front face (x=+0.11, eye level)
       Publishes:
         /rgbd_camera/image       → sensor_msgs/Image
         /rgbd_camera/depth_image → sensor_msgs/Image
         /rgbd_camera/points      → sensor_msgs/PointCloud2
       ─────────────────────────────────────────────── -->
  <sensor name="rgbd_camera" type="rgbd_camera">
    <pose>0.11 0 0.05 0 0 0</pose>
    <always_on>true</always_on>
    <update_rate>30</update_rate>
    <topic>rgbd_camera</topic>
    <camera name="rgbd">
      <horizontal_fov>1.0472</horizontal_fov>
      <image>
        <width>640</width>
        <height>480</height>
        <format>R8G8B8</format>
      </image>
      <clip><near>0.1</near><far>10.0</far></clip>
    </camera>
  </sensor>
</link>

<joint name="torso_joint" type="fixed">
  <parent>chassis</parent>
  <child>torso</child>
</joint>

<!-- ═══════════════════════════════════════════════════
     IMU  (on chassis)
     Publishes: /imu → sensor_msgs/Imu
     ═══════════════════════════════════════════════════ -->
<link name="imu_link">
  <pose relative_to="chassis">0 0 0.01 0 0 0</pose>
  <inertial>
    <mass>0.01</mass>
    <inertia>
      <ixx>0.0000001</ixx><ixy>0</ixy><ixz>0</ixz>
      <iyy>0.0000001</iyy><iyz>0</iyz>
      <izz>0.0000001</izz>
    </inertia>
  </inertial>
  <sensor name="imu_sensor" type="imu">
    <always_on>true</always_on>
    <update_rate>100</update_rate>
    <topic>imu</topic>
    <imu>
      <angular_velocity>
        <x><noise type="gaussian"><mean>0</mean><stddev>0.009</stddev></noise></x>
        <y><noise type="gaussian"><mean>0</mean><stddev>0.009</stddev></noise></y>
        <z><noise type="gaussian"><mean>0</mean><stddev>0.009</stddev></noise></z>
      </angular_velocity>
      <linear_acceleration>
        <x><noise type="gaussian"><mean>0</mean><stddev>0.021</stddev></noise></x>
        <y><noise type="gaussian"><mean>0</mean><stddev>0.021</stddev></noise></y>
        <z><noise type="gaussian"><mean>0</mean><stddev>0.021</stddev></noise></z>
      </linear_acceleration>
    </imu>
  </sensor>
</link>

<joint name="imu_joint" type="fixed">
  <parent>chassis</parent>
  <child>imu_link</child>
</joint>

<!-- ═══════════════════════════════════════════════════
     BUMPER CONTACT SENSOR  (additional sensor)
     Publishes: /bumper/contact → ros_gz_interfaces/Contacts
     ═══════════════════════════════════════════════════ -->
<link name="bumper_link">
  <pose relative_to="chassis">0.21 0 0 0 0 0</pose>
  <inertial>
    <mass>0.01</mass>
    <inertia>
      <ixx>0.0000001</ixx><ixy>0</ixy><ixz>0</ixz>
      <iyy>0.0000001</iyy><iyz>0</iyz>
      <izz>0.0000001</izz>
    </inertia>
  </inertial>
  <collision name="bumper_collision">
    <geometry><box><size>0.01 0.28 0.10</size></box></geometry>
  </collision>
  <visual name="bumper_visual">
    <geometry><box><size>0.01 0.28 0.10</size></box></geometry>
    <material>
      <ambient>1.0 0.3 0.0 1</ambient>
      <diffuse>1.0 0.3 0.0 1</diffuse>
    </material>
  </visual>
  <sensor name="bumper_contact" type="contact">
    <always_on>true</always_on>
    <update_rate>10</update_rate>
    <topic>bumper/contact</topic>
    <contact>
      <collision>bumper_collision</collision>
    </contact>
  </sensor>
</link>

<joint name="bumper_joint" type="fixed">
  <parent>chassis</parent>
  <child>bumper_link</child>
</joint>

<!-- ═══════════════════════════════════════════════════
     RIGHT ARM  (active, 3-DOF + parallel jaw gripper)
     All arm poses relative to parent link

     REACH VERIFICATION:
       shoulder world z = 0.450 + 0.100 = 0.550m
       arm total length = 0.20+0.18+0.10+0.09 = 0.57m
       0.57 > 0.55  →  reaches ground ✓
     ═══════════════════════════════════════════════════ -->

<!-- SHOULDER JOINT -->
<joint name="shoulder_joint" type="revolute">
  <pose relative_to="torso">0.0 -0.10 0.10 0 0 0</pose>
  <parent>torso</parent>
  <child>upper_arm_right</child>
  <axis>
    <xyz expressed_in="__model__">0 1 0</xyz>
    <limit>
      <lower>-1.5708</lower>
      <upper>1.5708</upper>
      <effort>20</effort>
      <velocity>1.0</velocity>
    </limit>
    <dynamics><damping>1.0</damping><friction>0.2</friction></dynamics>
  </axis>
</joint>

<!-- UPPER ARM
     Box: 0.06 × 0.06 × 0.20 m   mass: 0.30 kg
     Centre = 0.10m below shoulder joint
     Ixx=Iyy = 0.30/12*(0.06²+0.20²) = 0.001090
     Izz     = 0.30/12*(0.06²+0.06²) = 0.000180 -->
<link name="upper_arm_right">
  <pose relative_to="shoulder_joint">0 0 -0.10 0 0 0</pose>
  <inertial>
    <mass>0.30</mass>
    <inertia>
      <ixx>0.001090</ixx><ixy>0</ixy><ixz>0</ixz>
      <iyy>0.001090</iyy><iyz>0</iyz>
      <izz>0.000180</izz>
    </inertia>
  </inertial>
  <visual name="visual">
    <geometry><box><size>0.06 0.06 0.20</size></box></geometry>
    <material>
      <ambient>0.6 0.6 0.85 1</ambient>
      <diffuse>0.6 0.6 0.85 1</diffuse>
    </material>
  </visual>
  <collision name="collision">
    <geometry><box><size>0.06 0.06 0.20</size></box></geometry>
  </collision>
</link>

<!-- ELBOW JOINT -->
<joint name="elbow_joint" type="revolute">
  <pose relative_to="upper_arm_right">0 0 -0.10 0 0 0</pose>
  <parent>upper_arm_right</parent>
  <child>forearm_right</child>
  <axis>
    <xyz expressed_in="__model__">0 1 0</xyz>
    <limit>
      <lower>-2.0944</lower>
      <upper>0.0</upper>
      <effort>15</effort>
      <velocity>1.0</velocity>
    </limit>
    <dynamics><damping>0.8</damping><friction>0.15</friction></dynamics>
  </axis>
</joint>

<!-- FOREARM
     Box: 0.05 × 0.05 × 0.18 m   mass: 0.20 kg
     Ixx=Iyy = 0.20/12*(0.05²+0.18²) = 0.000582
     Izz     = 0.20/12*(0.05²+0.05²) = 0.000083 -->
<link name="forearm_right">
  <pose relative_to="elbow_joint">0 0 -0.09 0 0 0</pose>
  <inertial>
    <mass>0.20</mass>
    <inertia>
      <ixx>0.000582</ixx><ixy>0</ixy><ixz>0</ixz>
      <iyy>0.000582</iyy><iyz>0</iyz>
      <izz>0.000083</izz>
    </inertia>
  </inertial>
  <visual name="visual">
    <geometry><box><size>0.05 0.05 0.18</size></box></geometry>
    <material>
      <ambient>0.6 0.6 0.85 1</ambient>
      <diffuse>0.6 0.6 0.85 1</diffuse>
    </material>
  </visual>
  <collision name="collision">
    <geometry><box><size>0.05 0.05 0.18</size></box></geometry>
  </collision>
</link>

<!-- WRIST JOINT -->
<joint name="wrist_joint" type="revolute">
  <pose relative_to="forearm_right">0 0 -0.09 0 0 0</pose>
  <parent>forearm_right</parent>
  <child>wrist_right</child>
  <axis>
    <xyz expressed_in="__model__">0 1 0</xyz>
    <limit>
      <lower>-1.5708</lower>
      <upper>1.5708</upper>
      <effort>10</effort>
      <velocity>1.0</velocity>
    </limit>
    <dynamics><damping>0.5</damping><friction>0.1</friction></dynamics>
  </axis>
</joint>

<!-- WRIST LINK
     Box: 0.05 × 0.05 × 0.10 m   mass: 0.10 kg
     Ixx=Iyy = 0.10/12*(0.05²+0.10²) = 0.000104
     Izz     = 0.10/12*(0.05²+0.05²) = 0.000042 -->
<link name="wrist_right">
  <pose relative_to="wrist_joint">0 0 -0.05 0 0 0</pose>
  <inertial>
    <mass>0.10</mass>
    <inertia>
      <ixx>0.000104</ixx><ixy>0</ixy><ixz>0</ixz>
      <iyy>0.000104</iyy><iyz>0</iyz>
      <izz>0.000042</izz>
    </inertia>
  </inertial>
  <visual name="visual">
    <geometry><box><size>0.05 0.05 0.10</size></box></geometry>
    <material>
      <ambient>0.5 0.5 0.75 1</ambient>
      <diffuse>0.5 0.5 0.75 1</diffuse>
    </material>
  </visual>
  <collision name="collision">
    <geometry><box><size>0.05 0.05 0.10</size></box></geometry>
  </collision>
</link>

<!-- GRIPPER BASE (fixed to wrist)
     Box: 0.10 × 0.08 × 0.03 m   mass: 0.08 kg
     Ixx = 0.0000487  Iyy = 0.0000727  Izz = 0.0001093 -->
<joint name="gripper_base_joint" type="fixed">
  <pose relative_to="wrist_right">0 0 -0.05 0 0 0</pose>
  <parent>wrist_right</parent>
  <child>gripper_base</child>
</joint>

<link name="gripper_base">
  <pose relative_to="gripper_base_joint">0 0 -0.015 0 0 0</pose>
  <inertial>
    <mass>0.08</mass>
    <inertia>
      <ixx>0.0000487</ixx><ixy>0</ixy><ixz>0</ixz>
      <iyy>0.0000727</iyy><iyz>0</iyz>
      <izz>0.0001093</izz>
    </inertia>
  </inertial>
  <visual name="visual">
    <geometry><box><size>0.10 0.08 0.03</size></box></geometry>
    <material>
      <ambient>0.9 0.6 0.1 1</ambient>
      <diffuse>0.9 0.6 0.1 1</diffuse>
    </material>
  </visual>
  <collision name="collision">
    <geometry><box><size>0.10 0.08 0.03</size></box></geometry>
  </collision>
</link>

<!-- LEFT FINGER (prismatic, opens in +y)
     Box: 0.015 × 0.012 × 0.06 m   mass: 0.02 kg
     Ixx=Iyy = 0.00000624  Izz = 0.00000062 -->
<joint name="left_finger_joint" type="prismatic">
  <pose relative_to="gripper_base">0 0.02 -0.03 0 0 0</pose>
  <parent>gripper_base</parent>
  <child>left_finger</child>
  <axis>
    <xyz expressed_in="__model__">0 1 0</xyz>
    <limit>
      <lower>0</lower>
      <upper>0.04</upper>
      <effort>5</effort>
      <velocity>0.5</velocity>
    </limit>
    <dynamics><damping>0.3</damping><friction>0.05</friction></dynamics>
  </axis>
</joint>

<link name="left_finger">
  <pose relative_to="left_finger_joint">0 0 0 0 0 0</pose>
  <inertial>
    <mass>0.02</mass>
    <inertia>
      <ixx>0.00000624</ixx><ixy>0</ixy><ixz>0</ixz>
      <iyy>0.00000624</iyy><iyz>0</iyz>
      <izz>0.00000062</izz>
    </inertia>
  </inertial>
  <visual name="visual">
    <geometry><box><size>0.015 0.012 0.06</size></box></geometry>
    <material>
      <ambient>0.9 0.6 0.1 1</ambient>
      <diffuse>0.9 0.6 0.1 1</diffuse>
    </material>
  </visual>
  <collision name="collision">
    <geometry><box><size>0.015 0.012 0.06</size></box></geometry>
    <surface>
      <friction><ode><mu>1.2</mu><mu2>1.2</mu2></ode></friction>
      <contact><ode><min_depth>0.0005</min_depth></ode></contact>
    </surface>
  </collision>
</link>

<!-- RIGHT FINGER (prismatic, opens in -y) -->
<joint name="right_finger_joint" type="prismatic">
  <pose relative_to="gripper_base">0 -0.02 -0.03 0 0 0</pose>
  <parent>gripper_base</parent>
  <child>right_finger</child>
  <axis>
    <xyz expressed_in="__model__">0 -1 0</xyz>
    <limit>
      <lower>0</lower>
      <upper>0.04</upper>
      <effort>5</effort>
      <velocity>0.5</velocity>
    </limit>
    <dynamics><damping>0.3</damping><friction>0.05</friction></dynamics>
  </axis>
</joint>

<link name="right_finger">
  <pose relative_to="right_finger_joint">0 0 0 0 0 0</pose>
  <inertial>
    <mass>0.02</mass>
    <inertia>
      <ixx>0.00000624</ixx><ixy>0</ixy><ixz>0</ixz>
      <iyy>0.00000624</iyy><iyz>0</iyz>
      <izz>0.00000062</izz>
    </inertia>
  </inertial>
  <visual name="visual">
    <geometry><box><size>0.015 0.012 0.06</size></box></geometry>
    <material>
      <ambient>0.9 0.6 0.1 1</ambient>
      <diffuse>0.9 0.6 0.1 1</diffuse>
    </material>
  </visual>
  <collision name="collision">
    <geometry><box><size>0.015 0.012 0.06</size></box></geometry>
    <surface>
      <friction><ode><mu>1.2</mu><mu2>1.2</mu2></ode></friction>
      <contact><ode><min_depth>0.0005</min_depth></ode></contact>
    </surface>
  </collision>
</link>

<!-- ═══════════════════════════════════════════════════
     LEFT ARM (cosmetic — all fixed joints)
     Mirror geometry of right arm, no motors
     ═══════════════════════════════════════════════════ -->
<joint name="shoulder_joint_left" type="fixed">
  <pose relative_to="torso">0.0 0.10 0.10 0 0 0</pose>
  <parent>torso</parent>
  <child>upper_arm_left</child>
</joint>

<link name="upper_arm_left">
  <pose relative_to="shoulder_joint_left">0 0 -0.10 0 0 0</pose>
  <inertial>
    <mass>0.30</mass>
    <inertia>
      <ixx>0.001090</ixx><ixy>0</ixy><ixz>0</ixz>
      <iyy>0.001090</iyy><iyz>0</iyz>
      <izz>0.000180</izz>
    </inertia>
  </inertial>
  <visual name="visual">
    <geometry><box><size>0.06 0.06 0.20</size></box></geometry>
    <material>
      <ambient>0.6 0.6 0.85 1</ambient>
      <diffuse>0.6 0.6 0.85 1</diffuse>
    </material>
  </visual>
  <collision name="collision">
    <geometry><box><size>0.06 0.06 0.20</size></box></geometry>
  </collision>
</link>

<joint name="elbow_joint_left" type="fixed">
  <pose relative_to="upper_arm_left">0 0 -0.10 0 0 0</pose>
  <parent>upper_arm_left</parent>
  <child>forearm_left</child>
</joint>

<link name="forearm_left">
  <pose relative_to="elbow_joint_left">0 0 -0.09 0 0 0</pose>
  <inertial>
    <mass>0.20</mass>
    <inertia>
      <ixx>0.000582</ixx><ixy>0</ixy><ixz>0</ixz>
      <iyy>0.000582</iyy><iyz>0</iyz>
      <izz>0.000083</izz>
    </inertia>
  </inertial>
  <visual name="visual">
    <geometry><box><size>0.05 0.05 0.18</size></box></geometry>
    <material>
      <ambient>0.6 0.6 0.85 1</ambient>
      <diffuse>0.6 0.6 0.85 1</diffuse>
    </material>
  </visual>
  <collision name="collision">
    <geometry><box><size>0.05 0.05 0.18</size></box></geometry>
  </collision>
</link>

<joint name="wrist_joint_left" type="fixed">
  <pose relative_to="forearm_left">0 0 -0.09 0 0 0</pose>
  <parent>forearm_left</parent>
  <child>wrist_left</child>
</joint>

<link name="wrist_left">
  <pose relative_to="wrist_joint_left">0 0 -0.05 0 0 0</pose>
  <inertial>
    <mass>0.10</mass>
    <inertia>
      <ixx>0.000104</ixx><ixy>0</ixy><ixz>0</ixz>
      <iyy>0.000104</iyy><iyz>0</iyz>
      <izz>0.000042</izz>
    </inertia>
  </inertial>
  <visual name="visual">
    <geometry><box><size>0.05 0.05 0.10</size></box></geometry>
    <material>
      <ambient>0.5 0.5 0.75 1</ambient>
      <diffuse>0.5 0.5 0.75 1</diffuse>
    </material>
  </visual>
  <collision name="collision">
    <geometry><box><size>0.05 0.05 0.10</size></box></geometry>
  </collision>
</link>

<!-- ═══════════════════════════════════════════════════
     FACE PANEL  (visual only — LED display)
     Box: 0.18 × 0.03 × 0.14 m
     Emissive cyan — distinct color per spec
     Mounted on top front of torso
     ═══════════════════════════════════════════════════ -->
<joint name="face_panel_joint" type="fixed">
  <pose relative_to="torso">0.09 0 0.13 0 0 0</pose>
  <parent>torso</parent>
  <child>face_panel</child>
</joint>

<link name="face_panel">
  <pose relative_to="face_panel_joint">0 0 0.07 0 0 0</pose>
  <inertial>
    <mass>0.05</mass>
    <inertia>
      <ixx>0.0000324</ixx><ixy>0</ixy><ixz>0</ixz>
      <iyy>0.0000433</iyy><iyz>0</iyz>
      <izz>0.0000189</izz>
    </inertia>
  </inertial>
  <visual name="face_visual">
    <geometry><box><size>0.18 0.03 0.14</size></box></geometry>
    <material>
      <ambient>0.0 1.0 1.0 1</ambient>
      <diffuse>0.0 0.9 0.9 1</diffuse>
      <specular>0.8 0.8 0.8 1</specular>
      <emissive>0.0 0.4 0.4 1</emissive>
    </material>
  </visual>
  <!-- No collision — visual only per spec -->
</link>

    <!-- ═══════════════════════════════════════════════
         PLUGIN
         DiffDrive supports 4-wheel skid steer natively.
         SkidSteerDrive does not exist in Harmonic — removed.
         wheel_separation = 2 × 0.175 = 0.350 m
         ═══════════════════════════════════════════════ -->
    <plugin
      filename="gz-sim-diff-drive-system"
      name="gz::sim::systems::DiffDrive">
      <left_joint>front_left_wheel_joint</left_joint>
      <left_joint>rear_left_wheel_joint</left_joint>
      <right_joint>front_right_wheel_joint</right_joint>
      <right_joint>rear_right_wheel_joint</right_joint>
      <wheel_separation>0.35</wheel_separation>  <!-- FIXED: was 0.4 -->
      <wheel_radius>0.1</wheel_radius>
      <odom_publish_frequency>50</odom_publish_frequency>
      <max_linear_velocity>0.5</max_linear_velocity>
      <min_linear_velocity>-0.5</min_linear_velocity>
      <max_angular_velocity>1.0</max_angular_velocity>
      <min_angular_velocity>-1.0</min_angular_velocity>
      <max_linear_acceleration>1.0</max_linear_acceleration>
      <min_linear_acceleration>-1.0</min_linear_acceleration>
      <max_angular_acceleration>2.0</max_angular_acceleration>
      <min_angular_acceleration>-2.0</min_angular_acceleration>
      <topic>/model/diff_drive/cmd_vel</topic>
      <odom_topic>odom</odom_topic>
      <frame_id>odom</frame_id>
      <child_frame_id>base_link</child_frame_id>
    </plugin>

    <!-- Joint state publisher (needed for ROS tf tree) -->
    <plugin
      filename="gz-sim-joint-state-publisher-system"
      name="gz::sim::systems::JointStatePublisher">
      <topic>joint_states</topic>
    </plugin>

  </model>
</sdf>